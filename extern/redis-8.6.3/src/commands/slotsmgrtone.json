{
    "SLOTSMGRTONE": {
        "summary": "Synchronously migrate a single key to the target node.",
        "complexity": "O(1)",
        "group": "server",
        "since": "3.2.0",
        "arity": 5,
        "function": "slotsmgrtoneCommand",
        "command_flags": [
            "WRITE"
        ],
        "acl_categories": [
            "KEYSPACE",
            "DANGEROUS"
        ],
        "command_tips": [
            "NONDETERMINISTIC_OUTPUT"
        ],
        "key_specs": [
            {
                "flags": [
                    "RW",
                    "ACCESS",
                    "DELETE"
                ],
                "begin_search": {
                    "index": {
                        "pos": 4
                    }
                },
                "find_keys": {
                    "range": {
                        "lastkey": 0,
                        "step": 1,
                        "limit": 0
                    }
                }
            }
        ],
        "reply_schema": {
            "type": "integer",
            "description": "1 if the key was migrated, 0 if the key does not exist."
        },
        "arguments": [
            {
                "name": "host",
                "type": "string"
            },
            {
                "name": "port",
                "type": "integer"
            },
            {
                "name": "timeout",
                "type": "integer"
            },
            {
                "name": "key",
                "type": "key",
                "key_spec_index": 0
            }
        ]
    }
}
